<Window x:Class="DispHub.Windows.TaskbarWidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DispHub.Controls"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Width="140" Height="40"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        Visibility="Collapsed">
    <Canvas x:Name="WidgetCanvas" Background="Transparent">
        <controls:TaskbarWidgetControl x:Name="WidgetControl"/>
    </Canvas>
</Window>
