<Window x:Class="DisplayHub.Windows.TaskbarWidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DisplayHub.Controls"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="120" Height="40"
        ResizeMode="NoResize">
    <Canvas>
        <controls:TaskbarWidgetControl x:Name="WidgetControl"/>
    </Canvas>
</Window>
