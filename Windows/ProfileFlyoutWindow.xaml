<Window x:Class="DisplayHub.Windows.ProfileFlyoutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Height="56" Width="200"
    ResizeMode="NoResize"
    WindowStyle="None" ShowInTaskbar="False"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="True"
    Loaded="Window_Loaded">

    <Border x:Name="MainBorder" CornerRadius="8" Margin="4"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="10" ShadowDepth="2"/>
        </Border.Effect>
        <Grid Margin="14,6,14,6">
            <ui:SymbolIcon x:Name="ProfileIcon" HorizontalAlignment="Left"
                           Symbol="SlideMultiple24" Filled="False"
                           Width="22" Height="22" FontSize="22"
                           VerticalAlignment="Center" Margin="0,0,2,0"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                        HorizontalAlignment="Center" Margin="28,0,0,0">
                <TextBlock x:Name="ProfileNameText" Text="Default"
                           FontSize="14" FontWeight="Medium"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           TextTrimming="CharacterEllipsis" MaxWidth="130"/>
            </StackPanel>
            <Rectangle x:Name="AccentBar"
                       Fill="{DynamicResource SystemAccentColorPrimaryBrush}"
                       Height="3" RadiusX="2" RadiusY="2"
                       Width="50" VerticalAlignment="Bottom"
                       Margin="0,0,0,-4"/>
        </Grid>
    </Border>
</Window>
