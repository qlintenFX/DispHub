<ui:FluentWindow
    x:Class="DispHub.HotkeyDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Height="220" Width="400"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Title="Set Hotkey"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Grid>
        <ui:TitleBar Title="Set Hotkey" VerticalAlignment="Top"/>
        <StackPanel VerticalAlignment="Center" Margin="24,40,24,24">
            <TextBlock Text="Press a key combination..."
                       FontSize="16" FontWeight="Medium"
                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock x:Name="HotkeyText" Text="None"
                       FontSize="20" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,24"
                       Opacity="0.8"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <ui:Button x:Name="OkButton" Content="OK"
                           Appearance="Primary" IsEnabled="False"
                           Click="OkButton_Click" Margin="0,0,8,0" Width="80"/>
                <ui:Button Content="Cancel"
                           Click="CancelButton_Click" Width="80"/>
                <ui:Button Content="Clear"
                           Click="ClearButton_Click" Width="80" Margin="8,0,0,0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
