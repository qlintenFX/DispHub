<ui:FluentWindow x:Class="DisplayHub.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:pages="clr-namespace:DisplayHub.UI.Pages"
    Title="DisplayHub"
    Height="640" MinHeight="400" MinWidth="620" Width="820"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    Loaded="Window_Loaded"
    Closing="Window_Closing"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Grid>

        <!-- NavigationView — Margin leaves room for TitleBar (FluentFlyout pattern) -->
        <ui:NavigationView x:Name="NavigationView"
                           PaneDisplayMode="Left"
                           Margin="0,40,0,0"
                           FrameMargin="0,0,0,0"
                           OpenPaneLength="200"
                           TransitionDuration="200"
                           IsPaneToggleVisible="False"
                           IsBackButtonVisible="Collapsed"
                           IsTopSeparatorVisible="False"
                           IsFooterSeparatorVisible="False">

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Profiles"
                                       Icon="{ui:SymbolIcon ColorLine20}"
                                       TargetPageType="{x:Type pages:ProfilesPage}"/>
                <ui:NavigationViewItem Content="Dynamic Controls"
                                       Icon="{ui:SymbolIcon Gauge20}"
                                       TargetPageType="{x:Type pages:DynamicControlsPage}"/>
                <ui:NavigationViewItem Content="Settings"
                                       Icon="{ui:SymbolIcon Settings20}"
                                       TargetPageType="{x:Type pages:SettingsPage}"/>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="About"
                                       Icon="{ui:SymbolIcon Info20}"
                                       TargetPageType="{x:Type pages:AboutPage}"/>
            </ui:NavigationView.FooterMenuItems>

        </ui:NavigationView>

        <!-- TitleBar floats above NavigationView (FluentFlyout pattern) -->
        <ui:TitleBar x:Name="TitleBar"
                     Title="DisplayHub"
                     VerticalAlignment="Top">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/logo.png"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

    </Grid>
</ui:FluentWindow>
