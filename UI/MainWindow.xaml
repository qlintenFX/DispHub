<ui:FluentWindow x:Class="DisplayHub.UI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:pages="clr-namespace:DisplayHub.UI.Pages"
    Title="DisplayHub" Height="580" Width="520"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanMinimize"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    Loaded="Window_Loaded"
    Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar -->
        <ui:TitleBar Grid.Row="0" Title="DisplayHub" ShowMinimize="True" ShowMaximize="False" ShowClose="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/logo.png"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- Navigation View -->
        <ui:NavigationView x:Name="NavigationView"
                           Grid.Row="1"
                           PaneDisplayMode="Left"
                           IsBackButtonVisible="Collapsed"
                           IsPaneToggleVisible="False"
                           OpenPaneLength="180"
                           SelectionChanged="NavigationView_SelectionChanged">

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Profiles" Icon="{ui:SymbolIcon ColorLine20}" Tag="profiles"/>
                <ui:NavigationViewItem Content="Dynamic" Icon="{ui:SymbolIcon Gauge20}" Tag="dynamic"/>
                <ui:NavigationViewItem Content="Settings" Icon="{ui:SymbolIcon Settings20}" Tag="settings"/>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="About" Icon="{ui:SymbolIcon Info20}" Tag="about"/>
            </ui:NavigationView.FooterMenuItems>

        </ui:NavigationView>

        <Frame x:Name="ContentFrame" Grid.Row="1" Margin="180,0,0,0" NavigationUIVisibility="Hidden"/>
    </Grid>
</ui:FluentWindow>
