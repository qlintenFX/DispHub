<Page x:Class="DisplayHub.UI.Pages.ProfilesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Profiles"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="1000" Margin="16">

            <TextBlock Text="Display Profiles" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="Manage gamma, contrast, and vibrance presets" Opacity="0.6" Margin="0,0,0,16"/>

            <!-- Profile List -->
            <ui:CardExpander Header="Saved Profiles" IsExpanded="True"
                             Icon="{ui:SymbolIcon List20}" Margin="0,0,0,8">
                <StackPanel>
                    <ListBox x:Name="ProfileListBox" MinHeight="60" MaxHeight="200"
                             SelectionChanged="ProfileListBox_SelectionChanged"
                             MouseDoubleClick="ProfileListBox_MouseDoubleClick"
                             Background="Transparent" BorderThickness="0"
                             Margin="0,0,0,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="14"/>
                                    <TextBlock Grid.Column="1" Text="{Binding HotkeyDisplayText}"
                                               Opacity="0.5" FontSize="11"
                                               VerticalAlignment="Center" Margin="12,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HotkeyDisplayText}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <WrapPanel Margin="0,0,0,4">
                        <ui:Button Content="Apply" Icon="{ui:SymbolIcon Checkmark20}" Margin="0,0,8,4"
                                   Appearance="Primary" Click="ApplyProfile_Click"
                                   ToolTip="Apply selected profile (or double-click)"/>
                        <ui:Button Content="Add" Icon="{ui:SymbolIcon Add20}" Margin="0,0,8,4"
                                   Click="AddProfile_Click"/>
                        <ui:Button Content="Update" Icon="{ui:SymbolIcon ArrowSync20}" Margin="0,0,8,4"
                                   Click="UpdateProfile_Click"/>
                        <ui:Button Content="Delete" Icon="{ui:SymbolIcon Delete20}" Margin="0,0,8,4"
                                   Appearance="Danger" Click="DeleteProfile_Click"/>
                        <ui:Button Content="Set Hotkey" Icon="{ui:SymbolIcon Keyboard20}" Margin="0,0,0,4"
                                   Click="SetHotkey_Click"/>
                    </WrapPanel>
                    <TextBlock x:Name="HotkeyLabel" Text="Hotkey: None" Opacity="0.6" Margin="0,4,0,0" FontSize="12"/>
                </StackPanel>
            </ui:CardExpander>

            <!-- Display Settings -->
            <ui:CardExpander Header="Display Settings" IsExpanded="True" Margin="0,0,0,8"
                             Icon="{ui:SymbolIcon BrightnessHigh20}">
                <StackPanel>
                    <TextBlock Text="Gamma" FontWeight="Medium" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="54"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="GammaSlider" Minimum="30" Maximum="280" Value="100"
                                TickFrequency="10" IsSnapToTickEnabled="True"
                                ValueChanged="ProfileSlider_ValueChanged"/>
                        <TextBlock x:Name="GammaValueText" Grid.Column="1" Text="1.00"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock Text="Contrast" FontWeight="Medium" Margin="0,12,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="54"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="ContrastSlider" Minimum="0" Maximum="100" Value="50"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="ProfileSlider_ValueChanged"/>
                        <TextBlock x:Name="ContrastValueText" Grid.Column="1" Text="50%"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock Text="Vibrance" FontWeight="Medium" Margin="0,12,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="54"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="VibranceSlider" Minimum="0" Maximum="100" Value="50"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="ProfileSlider_ValueChanged"/>
                        <TextBlock x:Name="VibranceValueText" Grid.Column="1" Text="50%"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <ui:Button Content="Reset to Default" Icon="{ui:SymbolIcon ArrowReset20}"
                               HorizontalAlignment="Right" Margin="0,12,0,0"
                               Click="ResetButton_Click"/>
                </StackPanel>
            </ui:CardExpander>

        </StackPanel>
    </ScrollViewer>
</Page>
