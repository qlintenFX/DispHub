<Page x:Class="DisplayHub.UI.Pages.ProfilesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Profiles">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
        <StackPanel Margin="16">

            <!-- Header -->
            <TextBlock Text="Display Profiles" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="Manage gamma, contrast, and vibrance presets" Opacity="0.6" Margin="0,0,0,16"/>

            <!-- Profile List -->
            <ui:CardExpander Header="Saved Profiles" IsExpanded="True"
                             Icon="{ui:SymbolIcon List20}">
                <StackPanel>
                    <ListBox x:Name="ProfileListBox" MinHeight="80" MaxHeight="180"
                             SelectionChanged="ProfileListBox_SelectionChanged"
                             Background="Transparent" BorderThickness="0"
                             Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <ui:Button Content="Add" Icon="{ui:SymbolIcon Add20}" Margin="0,0,8,0"
                                   Appearance="Primary" Click="AddProfile_Click"/>
                        <ui:Button Content="Update" Icon="{ui:SymbolIcon ArrowSync20}" Margin="0,0,8,0"
                                   Click="UpdateProfile_Click"/>
                        <ui:Button Content="Delete" Icon="{ui:SymbolIcon Delete20}" Margin="0,0,8,0"
                                   Appearance="Danger" Click="DeleteProfile_Click"/>
                        <ui:Button Content="Set Hotkey" Icon="{ui:SymbolIcon Keyboard20}"
                                   Click="SetHotkey_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="HotkeyLabel" Text="Hotkey: None" Opacity="0.6" Margin="0,8,0,0"/>
                </StackPanel>
            </ui:CardExpander>

            <!-- Display Settings -->
            <ui:CardExpander Header="Display Settings" IsExpanded="True" Margin="0,8,0,0"
                             Icon="{ui:SymbolIcon Brightness20}">
                <StackPanel>
                    <!-- Gamma -->
                    <TextBlock Text="Gamma" FontWeight="Medium" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="GammaSlider" Minimum="30" Maximum="280" Value="100"
                                TickFrequency="10" IsSnapToTickEnabled="True"
                                ValueChanged="ProfileSlider_ValueChanged"/>
                        <TextBlock x:Name="GammaValueText" Grid.Column="1" Text="1.00"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Contrast -->
                    <TextBlock Text="Contrast" FontWeight="Medium" Margin="0,12,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="ContrastSlider" Minimum="0" Maximum="100" Value="50"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="ProfileSlider_ValueChanged"/>
                        <TextBlock x:Name="ContrastValueText" Grid.Column="1" Text="50%"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Vibrance -->
                    <TextBlock Text="Vibrance" FontWeight="Medium" Margin="0,12,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="VibranceSlider" Minimum="0" Maximum="100" Value="50"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="ProfileSlider_ValueChanged"/>
                        <TextBlock x:Name="VibranceValueText" Grid.Column="1" Text="50%"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Reset Button -->
                    <ui:Button Content="Reset to Default" Icon="{ui:SymbolIcon ArrowReset20}"
                               HorizontalAlignment="Right" Margin="0,12,0,0"
                               Click="ResetButton_Click"/>
                </StackPanel>
            </ui:CardExpander>

        </StackPanel>
    </ScrollViewer>
</Page>
