<Page x:Class="DisplayHub.UI.Pages.DynamicControlsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Dynamic Controls">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
        <StackPanel Margin="16">

            <!-- Header -->
            <TextBlock Text="Dynamic Controls" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="Adjust display settings in real-time with hotkeys" Opacity="0.6" Margin="0,0,0,16"/>

            <!-- Enable Toggle -->
            <ui:CardControl Margin="0,0,0,8"
                            Icon="{ui:SymbolIcon ToggleRight20}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Enable Dynamic Controls" FontWeight="Medium"/>
                        <TextBlock Text="Use keyboard shortcuts for live adjustments" Opacity="0.6" FontSize="12"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:CardControl.Content>
                    <ui:ToggleSwitch x:Name="DynamicToggle" Checked="DynamicToggle_Changed" Unchecked="DynamicToggle_Changed"/>
                </ui:CardControl.Content>
            </ui:CardControl>

            <!-- Sliders -->
            <ui:CardExpander Header="Live Settings" IsExpanded="True" Margin="0,0,0,8"
                             Icon="{ui:SymbolIcon Brightness20}">
                <StackPanel>
                    <!-- Gamma -->
                    <TextBlock Text="Gamma" FontWeight="Medium" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="DynamicGammaSlider" Minimum="30" Maximum="280" Value="100"
                                TickFrequency="10" IsSnapToTickEnabled="True"
                                ValueChanged="DynamicSlider_ValueChanged"/>
                        <TextBlock x:Name="DynGammaText" Grid.Column="1" Text="1.00"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Contrast -->
                    <TextBlock Text="Contrast" FontWeight="Medium" Margin="0,12,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="DynamicContrastSlider" Minimum="0" Maximum="100" Value="50"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="DynamicSlider_ValueChanged"/>
                        <TextBlock x:Name="DynContrastText" Grid.Column="1" Text="50%"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Vibrance -->
                    <TextBlock Text="Vibrance" FontWeight="Medium" Margin="0,12,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="DynamicVibranceSlider" Minimum="0" Maximum="100" Value="50"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="DynamicSlider_ValueChanged"/>
                        <TextBlock x:Name="DynVibranceText" Grid.Column="1" Text="50%"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <ui:Button Content="Reset" Icon="{ui:SymbolIcon ArrowReset20}" Margin="0,0,8,0"
                                   Click="DynamicReset_Click"/>
                        <ui:Button Content="Save as Profile" Icon="{ui:SymbolIcon Save20}"
                                   Appearance="Primary" Click="SaveToProfile_Click"/>
                    </StackPanel>
                </StackPanel>
            </ui:CardExpander>

            <!-- Hotkey Help -->
            <ui:CardExpander Header="Keyboard Shortcuts" IsExpanded="False" Margin="0,0,0,8"
                             Icon="{ui:SymbolIcon Keyboard20}">
                <StackPanel>
                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Shift + Up/Down" FontWeight="Medium"/>
                        <TextBlock Grid.Column="1" Text="Adjust Gamma" Opacity="0.7"/>
                    </Grid>
                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Shift + Left/Right" FontWeight="Medium"/>
                        <TextBlock Grid.Column="1" Text="Adjust Contrast" Opacity="0.7"/>
                    </Grid>
                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Shift + PageUp/Down" FontWeight="Medium"/>
                        <TextBlock Grid.Column="1" Text="Adjust Vibrance" Opacity="0.7"/>
                    </Grid>
                </StackPanel>
            </ui:CardExpander>

        </StackPanel>
    </ScrollViewer>
</Page>
