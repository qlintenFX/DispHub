<Page x:Class="DisplayHub.UI.Pages.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="About">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
        <StackPanel Margin="16">

            <!-- Header -->
            <TextBlock Text="About" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16"/>

            <StackPanel HorizontalAlignment="Center" Margin="0,16,0,0">
                <Image Source="/logo.png" Width="64" Height="64" HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,0,12"/>
                <TextBlock Text="DisplayHub" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="Version 3.0.0" Opacity="0.6" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                <TextBlock Text="Modern display profile manager" Opacity="0.6" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>

            <ui:CardControl Margin="0,24,0,8"
                            Icon="{ui:SymbolIcon Brightness20}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Display Controls" FontWeight="Medium"/>
                        <TextBlock Text="Gamma, contrast, and NVIDIA vibrance adjustment" Opacity="0.6" FontSize="12"/>
                    </StackPanel>
                </ui:CardControl.Header>
            </ui:CardControl>

            <ui:CardControl Margin="0,0,0,8"
                            Icon="{ui:SymbolIcon Keyboard20}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Hotkey Support" FontWeight="Medium"/>
                        <TextBlock Text="Global hotkeys for quick profile switching" Opacity="0.6" FontSize="12"/>
                    </StackPanel>
                </ui:CardControl.Header>
            </ui:CardControl>

            <ui:CardControl Margin="0,0,0,8"
                            Icon="{ui:SymbolIcon Gauge20}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Dynamic Controls" FontWeight="Medium"/>
                        <TextBlock Text="Real-time adjustments with Shift+Arrow keys" Opacity="0.6" FontSize="12"/>
                    </StackPanel>
                </ui:CardControl.Header>
            </ui:CardControl>

        </StackPanel>
    </ScrollViewer>
</Page>
