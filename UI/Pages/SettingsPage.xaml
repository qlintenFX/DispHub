<Page x:Class="DisplayHub.UI.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Settings">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
        <StackPanel Margin="16">

            <!-- Header -->
            <TextBlock Text="Settings" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="Configure application behavior" Opacity="0.6" Margin="0,0,0,16"/>

            <!-- Start with Windows -->
            <ui:CardControl Margin="0,0,0,8"
                            Icon="{ui:SymbolIcon Power20}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Start with Windows" FontWeight="Medium"/>
                        <TextBlock Text="Launch DisplayHub automatically when you sign in" Opacity="0.6" FontSize="12"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:CardControl.Content>
                    <ui:ToggleSwitch x:Name="StartupToggle" Checked="StartupToggle_Changed" Unchecked="StartupToggle_Changed"/>
                </ui:CardControl.Content>
            </ui:CardControl>

            <!-- Minimize to Tray -->
            <ui:CardControl Margin="0,0,0,8"
                            Icon="{ui:SymbolIcon ArrowMinimize20}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="Minimize to tray" FontWeight="Medium"/>
                        <TextBlock Text="Hide to system tray instead of closing" Opacity="0.6" FontSize="12"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:CardControl.Content>
                    <ui:ToggleSwitch x:Name="MinimizeToTrayToggle" Checked="MinimizeToTrayToggle_Changed" Unchecked="MinimizeToTrayToggle_Changed"/>
                </ui:CardControl.Content>
            </ui:CardControl>

        </StackPanel>
    </ScrollViewer>
</Page>
