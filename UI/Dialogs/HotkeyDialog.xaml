<ui:FluentWindow x:Class="DisplayHub.UI.Dialogs.HotkeyDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Set Hotkey"
                 Width="360" Height="200"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <ui:TitleBar Title="Set Hotkey" Grid.Row="0"/>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="16,8,16,8">
            <TextBlock Text="Press a key combination (e.g. Ctrl+Shift+A):"
                       Opacity="0.8" Margin="0,0,0,8"/>
            <ui:TextBox x:Name="HotkeyTextBox"
                        IsReadOnly="True"
                        PlaceholderText="Press a key combination..."
                        KeyDown="HotkeyTextBox_KeyDown"
                        PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"/>
            <TextBlock x:Name="ErrorText" Foreground="OrangeRed" FontSize="11"
                       Margin="0,4,0,0" Visibility="Collapsed"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="16,0,16,16">
            <ui:Button Content="Clear" Margin="0,0,8,0" Click="ClearButton_Click"/>
            <ui:Button Content="Cancel" Margin="0,0,8,0" IsCancel="True"/>
            <ui:Button x:Name="OkButton" Content="OK" Appearance="Primary"
                       IsDefault="True" Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
