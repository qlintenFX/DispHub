<Page x:Class="DisplayHub.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:DisplayHub.Helpers"
      Title="Home"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16"
                  helpers:SmoothScrollBehavior.IsEnabled="True">
        <StackPanel MaxWidth="1000">
            <!-- App Header -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                <Image Source="/logo.png" Width="44" Height="44"/>
                <TextBlock Text="DisplayHub" FontSize="24" FontWeight="Medium" Margin="12,0,0,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="VersionTextBlock" FontSize="14" FontWeight="Regular" VerticalAlignment="Bottom"
                           Margin="10" Opacity="0.5"/>
            </StackPanel>

            <!-- Dashboard -->
            <TextBlock Text="Dashboard" FontSize="14" FontWeight="SemiBold" Margin="0,36,0,6"/>
            <Grid Margin="-4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ui:CardAction Grid.Row="0" Grid.Column="0" Margin="4" Padding="12,20" IsChevronVisible="True" Click="Profiles_Click">
                    <ui:CardAction.Icon>
                        <ui:SymbolIcon Symbol="SlideMultiple24" FontSize="30" Filled="False"/>
                    </ui:CardAction.Icon>
                    <StackPanel>
                        <ui:TextBlock FontWeight="Medium" Text="Profiles"/>
                        <ui:TextBlock x:Name="ProfileStatusText" Appearance="Secondary" Text="3 profiles" FontSize="12"/>
                    </StackPanel>
                </ui:CardAction>

                <ui:CardAction Grid.Row="0" Grid.Column="1" Margin="4" Padding="12,20" IsChevronVisible="True" Click="DynamicControls_Click">
                    <ui:CardAction.Icon>
                        <ui:SymbolIcon Symbol="Gauge20" FontSize="30" Filled="False"/>
                    </ui:CardAction.Icon>
                    <StackPanel>
                        <ui:TextBlock FontWeight="Medium" Text="Dynamic Controls"/>
                        <ui:TextBlock x:Name="DcStatusText" Appearance="Secondary" Text="Disabled" FontSize="12"/>
                    </StackPanel>
                </ui:CardAction>

                <ui:CardAction Grid.Row="1" Grid.Column="0" Margin="4" Padding="12,20" IsChevronVisible="True" Click="Settings_Click">
                    <ui:CardAction.Icon>
                        <ui:SymbolIcon Symbol="Settings24" FontSize="30" Filled="False"/>
                    </ui:CardAction.Icon>
                    <StackPanel>
                        <ui:TextBlock FontWeight="Medium" Text="Settings"/>
                        <ui:TextBlock Appearance="Secondary" Text="Configure" FontSize="12"/>
                    </StackPanel>
                </ui:CardAction>

                <ui:CardAction Grid.Row="1" Grid.Column="1" Margin="4" Padding="12,20" IsChevronVisible="True" Click="About_Click">
                    <ui:CardAction.Icon>
                        <ui:SymbolIcon Symbol="Info20" FontSize="30" Filled="False"/>
                    </ui:CardAction.Icon>
                    <StackPanel>
                        <ui:TextBlock FontWeight="Medium" Text="About"/>
                        <ui:TextBlock Appearance="Secondary" Text="Credits &amp; licenses" FontSize="12"/>
                    </StackPanel>
                </ui:CardAction>
            </Grid>

            <!-- Quick status -->
            <TextBlock Text="Status" FontSize="14" FontWeight="SemiBold" Margin="0,24,0,6"/>
            <ui:Card Margin="0,0,0,12" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Display Power" FontSize="12" Opacity="0.6"/>
                        <TextBlock x:Name="PowerStatusText" Text="Active" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Active Profile" FontSize="12" Opacity="0.6"/>
                        <TextBlock x:Name="ActiveProfileText" Text="None" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- Quick Links -->
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <ui:Button Appearance="Transparent" Padding="16,4,16,0" Height="56" BorderBrush="Transparent" Margin="0,0,8,0" Click="GitHub_Click">
                    <StackPanel VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Open24" FontSize="18" Filled="False"/>
                        <ui:TextBlock Text="GitHub" FontWeight="Normal"/>
                    </StackPanel>
                </ui:Button>
                <ui:Button Appearance="Transparent" Padding="16,4,16,0" Height="56" BorderBrush="Transparent" Margin="0,0,8,0" Click="ReportBug_Click">
                    <StackPanel VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Bug20" FontSize="18" Filled="False"/>
                        <ui:TextBlock Text="Report Bug" FontWeight="Normal"/>
                    </StackPanel>
                </ui:Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
