<Page x:Class="DisplayHub.Pages.ProfilesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Profiles"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
        <StackPanel MaxWidth="700">
            <TextBlock Text="Profiles" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <ui:InfoBar x:Name="DcWarningBar"
                        Title="Dynamic Controls Active"
                        Message="Disable Dynamic Controls first to switch profiles."
                        Severity="Warning" IsOpen="False" IsClosable="False"
                        Margin="0,0,0,12"/>

            <!-- Profile Cards -->
            <WrapPanel x:Name="ProfileCardPanel" Orientation="Horizontal" Margin="0,0,0,16"/>

            <!-- Sliders -->
            <StackPanel x:Name="SlidersPanel">
                <ui:Card Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:SymbolIcon Symbol="BrightnessHigh20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Gamma" FontWeight="Medium" VerticalAlignment="Center"/>
                            <TextBlock x:Name="GammaValueText" Text="1.00"
                                       Opacity="0.6" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Slider x:Name="GammaSlider"
                                Minimum="0.30" Maximum="2.80"
                                TickFrequency="0.05" IsSnapToTickEnabled="True"
                                ValueChanged="GammaSlider_ValueChanged"/>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,12">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:SymbolIcon Symbol="ArrowSync20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Contrast" FontWeight="Medium" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ContrastValueText" Text="50%"
                                       Opacity="0.6" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Slider x:Name="ContrastSlider"
                                Minimum="0.00" Maximum="1.00"
                                TickFrequency="0.05" IsSnapToTickEnabled="True"
                                ValueChanged="ContrastSlider_ValueChanged"/>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:SymbolIcon Symbol="FlashSettings20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Vibrance" FontWeight="Medium" VerticalAlignment="Center"/>
                            <TextBlock x:Name="VibranceValueText" Text="50"
                                       Opacity="0.6" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Slider x:Name="VibranceSlider"
                                Minimum="0" Maximum="100"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="VibranceSlider_ValueChanged"/>
                    </StackPanel>
                </ui:Card>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel x:Name="ActionButtonsPanel" Orientation="Horizontal">
                <ui:Button x:Name="SaveButton" Content="Save" Icon="{ui:SymbolIcon Save20}"
                           Appearance="Primary" Margin="0,0,8,0" Click="Save_Click"/>
                <ui:Button x:Name="SetHotkeyButton" Content="Set Hotkey" Icon="{ui:SymbolIcon Keyboard20}"
                           Appearance="Secondary" Margin="0,0,8,0" Click="SetHotkey_Click"/>
                <ui:Button x:Name="AddProfileButton" Content="Add" Icon="{ui:SymbolIcon Add20}"
                           Appearance="Secondary" Margin="0,0,8,0" Click="AddProfile_Click"/>
                <ui:Button x:Name="DeleteProfileButton" Content="Delete" Icon="{ui:SymbolIcon Delete20}"
                           Appearance="Secondary" Margin="0,0,8,0" Click="DeleteProfile_Click"/>
                <ui:Button x:Name="ResetDefaultButton" Content="Reset to Default" Icon="{ui:SymbolIcon ArrowReset20}"
                           Appearance="Secondary" Click="ResetToDefault_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
