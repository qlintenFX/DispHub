<Page x:Class="DisplayHub.Pages.ProfilesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Profiles"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <StackPanel MaxWidth="700" Margin="16">
        <TextBlock Text="Profiles" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>

        <!-- Preview placeholder -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Border CornerRadius="10" ClipToBounds="True" Width="164" Height="98"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="SlideMultiple24" FontSize="28" Opacity="0.3"/>
                    <TextBlock Text="Preview" FontSize="10" Opacity="0.3" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <TextBlock Text="Create and manage display profiles with custom gamma, contrast, and vibrance settings. Assign hotkeys for instant switching."
                       FontSize="13" Opacity="0.6" Margin="16,0,0,0" MaxWidth="400"
                       TextWrapping="WrapWithOverflow" VerticalAlignment="Center"/>
        </StackPanel>

        <ui:InfoBar x:Name="PowerOffBar"
                    Title="DisplayHub Disabled"
                    Severity="Error" IsOpen="False" IsClosable="False"
                    Margin="0,0,0,12"/>

        <ui:InfoBar x:Name="DcWarningBar"
                    Title="Dynamic Controls Active"
                    Severity="Warning" IsOpen="False" IsClosable="False"
                    Margin="0,0,0,12"/>

        <!-- Profile Cards -->
        <WrapPanel x:Name="ProfileCardPanel" Orientation="Horizontal" Margin="0,0,0,16"/>

        <!-- Sliders -->
        <StackPanel x:Name="SlidersPanel">
            <ui:Card Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ui:SymbolIcon Symbol="BrightnessHigh20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Gamma" FontWeight="Medium" VerticalAlignment="Center" 
                                   MouseRightButtonUp="GammaLabel_RightClick" Cursor="Hand"
                                   ToolTip="Right-click to reset"/>
                        <TextBlock x:Name="GammaValueText" Text="1.00"
                                   Opacity="0.6" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Slider x:Name="GammaSlider"
                            Minimum="0.30" Maximum="2.80"
                            TickFrequency="0.01"
                            ValueChanged="GammaSlider_ValueChanged"
                            MouseRightButtonUp="GammaSlider_RightClick"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <ui:Button Content="Reset" Appearance="Transparent" Padding="8,2"
                                   FontSize="11" Click="GammaReset_Click"/>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ui:SymbolIcon Symbol="ArrowSync20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Contrast" FontWeight="Medium" VerticalAlignment="Center"
                                   MouseRightButtonUp="ContrastLabel_RightClick" Cursor="Hand"
                                   ToolTip="Right-click to reset"/>
                        <TextBlock x:Name="ContrastValueText" Text="50%"
                                   Opacity="0.6" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Slider x:Name="ContrastSlider"
                            Minimum="0.00" Maximum="1.00"
                            TickFrequency="0.01"
                            ValueChanged="ContrastSlider_ValueChanged"
                            MouseRightButtonUp="ContrastSlider_RightClick"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <ui:Button Content="Reset" Appearance="Transparent" Padding="8,2"
                                   FontSize="11" Click="ContrastReset_Click"/>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ui:SymbolIcon Symbol="FlashSettings20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Vibrance" FontWeight="Medium" VerticalAlignment="Center"
                                   MouseRightButtonUp="VibranceLabel_RightClick" Cursor="Hand"
                                   ToolTip="Right-click to reset"/>
                        <TextBlock x:Name="VibranceValueText" Text="50"
                                   Opacity="0.6" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Slider x:Name="VibranceSlider"
                            Minimum="0" Maximum="100"
                            TickFrequency="1"
                            ValueChanged="VibranceSlider_ValueChanged"
                            MouseRightButtonUp="VibranceSlider_RightClick"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <ui:Button Content="Reset" Appearance="Transparent" Padding="8,2"
                                   FontSize="11" Click="VibranceReset_Click"/>
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <ui:Card Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ui:SymbolIcon Symbol="WeatherMoon20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Color Temperature" FontWeight="Medium" VerticalAlignment="Center"
                                   MouseRightButtonUp="ColorTempLabel_RightClick" Cursor="Hand"
                                   ToolTip="Right-click to reset"/>
                        <TextBlock x:Name="ColorTempValueText" Text="Neutral"
                                    Opacity="0.6" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Warm" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                        <Slider x:Name="ColorTempSlider" Grid.Column="1"
                                Minimum="0" Maximum="100"
                                TickFrequency="5" Margin="8,0"
                                ValueChanged="ColorTempSlider_ValueChanged"
                                MouseRightButtonUp="ColorTempSlider_RightClick"/>
                        <TextBlock Grid.Column="2" Text="Cool" FontSize="11" Opacity="0.7" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock x:Name="ColorTempKelvinText" Text="6500 K"
                               FontSize="11" Opacity="0.7" Margin="0,6,0,0" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <ui:Button Content="Reset" Appearance="Transparent" Padding="8,2"
                                   FontSize="11" Click="ColorTempReset_Click"/>
                    </StackPanel>
                </StackPanel>
            </ui:Card>
        </StackPanel>

        <!-- Action Buttons -->
        <StackPanel x:Name="ActionButtonsPanel" Orientation="Horizontal">
            <ui:Button x:Name="SaveButton" Content="Save" Icon="{ui:SymbolIcon Save20}"
                       Appearance="Primary" Margin="0,0,8,0" Click="Save_Click"/>
            <ui:Button x:Name="SetHotkeyButton" Content="Set Hotkey" Icon="{ui:SymbolIcon Keyboard20}"
                       Appearance="Secondary" Margin="0,0,8,0" Click="SetHotkey_Click"/>
            <ui:Button x:Name="AddProfileButton" Content="Add" Icon="{ui:SymbolIcon Add20}"
                       Appearance="Secondary" Margin="0,0,8,0" Click="AddProfile_Click"/>
            <ui:Button x:Name="DeleteProfileButton" Content="Delete" Icon="{ui:SymbolIcon Delete20}"
                       Appearance="Secondary" Margin="0,0,8,0" Click="DeleteProfile_Click"/>
            <ui:Button x:Name="ResetDefaultButton" Content="Reset to Default" Icon="{ui:SymbolIcon ArrowReset20}"
                       Appearance="Secondary" Click="ResetToDefault_Click"/>
        </StackPanel>
    </StackPanel>
</Page>
