<Page x:Class="DisplayHub.Pages.FlyoutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Flyout"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <StackPanel MaxWidth="700" Margin="16">
        <TextBlock Text="Flyout" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>

        <!-- Preview placeholder -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Border CornerRadius="10" ClipToBounds="True" Width="164" Height="98"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="Alert24" FontSize="28" Opacity="0.3"/>
                    <TextBlock Text="Flyout Preview" FontSize="10" Opacity="0.3" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <TextBlock Text="A small popup that appears when you switch profiles using hotkeys. Shows the name of the active profile briefly before fading away."
                       FontSize="13" Opacity="0.6" Margin="16,0,0,0" MaxWidth="400"
                       TextWrapping="WrapWithOverflow" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Enable -->
        <ui:CardControl Margin="0,0,0,8">
            <ui:CardControl.Header>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Enable Profile Flyout" FontSize="14" FontWeight="Regular"/>
                    <TextBlock Text="Show a popup notification when switching profiles via hotkeys" FontSize="12" Opacity="0.5"/>
                </StackPanel>
            </ui:CardControl.Header>
            <ui:ToggleSwitch x:Name="FlyoutEnabledToggle"
                             Checked="FlyoutEnabled_Changed"
                             Unchecked="FlyoutEnabled_Changed"/>
        </ui:CardControl>

        <!-- Duration -->
        <ui:CardControl Margin="0,0,0,8">
            <ui:CardControl.Header>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Stay Duration" FontSize="14" FontWeight="Regular"/>
                    <TextBlock Text="How long the flyout stays visible before fading" FontSize="12" Opacity="0.5"/>
                </StackPanel>
            </ui:CardControl.Header>
            <StackPanel Orientation="Horizontal">
                <ui:TextBox x:Name="DurationTextBox" Width="60" ClearButtonEnabled="False"
                            TextChanged="Duration_TextChanged"/>
                <TextBlock Text="ms" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </ui:CardControl>

        <ui:InfoBar IsOpen="True" Severity="Informational" IsClosable="False" Margin="0,8,0,0"
                    Title="Tip"
                    Message="The flyout appears at the bottom center of your screen when you switch profiles via hotkeys or the system tray. Default duration is 1800ms."/>
    </StackPanel>
</Page>
