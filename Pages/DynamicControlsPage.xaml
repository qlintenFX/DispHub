<Page x:Class="DisplayHub.Pages.DynamicControlsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Dynamic Controls"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <StackPanel MaxWidth="700" Margin="16">
        <TextBlock Text="Dynamic Controls" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <ui:InfoBar x:Name="DcActiveInfoBar"
                    Title="Dynamic Controls active"
                    Message="Profile switching is disabled. Adjust display settings in real-time using hotkeys."
                    Severity="Informational" IsOpen="False" IsClosable="False"
                    Margin="0,0,0,12"/>

        <ui:Card Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="Enable Dynamic Controls" FontWeight="Medium" FontSize="14"/>
                    <TextBlock Text="Adjust display settings with hotkeys in real-time"
                               Opacity="0.6" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
                <ui:ToggleSwitch x:Name="DynamicControlsToggle"
                                 Checked="DynamicControlsToggle_Changed"
                                 Unchecked="DynamicControlsToggle_Changed"
                                 HorizontalAlignment="Right"/>
            </StackPanel>
        </ui:Card>

        <ui:Card Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Current Values" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Gamma:" FontWeight="Medium" Margin="0,0,16,8"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="GammaValueText" Text="1.00" Opacity="0.8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Contrast:" FontWeight="Medium" Margin="0,0,16,8"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ContrastValueText" Text="50%" Opacity="0.8"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Vibrance:" FontWeight="Medium" Margin="0,0,16,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="VibranceValueText" Text="50" Opacity="0.8"/>
                </Grid>
            </StackPanel>
        </ui:Card>

        <ui:Card>
            <StackPanel>
                <TextBlock Text="Hotkey Reference" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Shift+Up" FontFamily="Consolas" Margin="0,0,16,8" Opacity="0.8"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Increase Gamma" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Shift+Down" FontFamily="Consolas" Margin="0,0,16,8" Opacity="0.8"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Decrease Gamma" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Shift+Right" FontFamily="Consolas" Margin="0,0,16,8" Opacity="0.8"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Increase Contrast" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Shift+Left" FontFamily="Consolas" Margin="0,0,16,8" Opacity="0.8"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Decrease Contrast" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Shift+Page Up" FontFamily="Consolas" Margin="0,0,16,8" Opacity="0.8"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="Increase Vibrance" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Shift+Page Down" FontFamily="Consolas" Margin="0,0,16,0" Opacity="0.8"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="Decrease Vibrance"/>
                </Grid>
            </StackPanel>
        </ui:Card>
    </StackPanel>
</Page>
