<Page x:Class="DisplayHub.Pages.DynamicControlsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Dynamic Controls"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <StackPanel MaxWidth="700" Margin="16">
        <TextBlock Text="Dynamic Controls" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>

        <!-- Preview placeholder -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Border CornerRadius="10" ClipToBounds="True" Width="164" Height="98"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="Gauge24" FontSize="28" Opacity="0.3"/>
                    <TextBlock Text="Preview" FontSize="10" Opacity="0.3" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <TextBlock Text="Adjust display settings in real-time using customizable hotkeys. Switch between Dynamic Controls and Profile modes."
                       FontSize="13" Opacity="0.6" Margin="16,0,0,0" MaxWidth="400"
                       TextWrapping="WrapWithOverflow" VerticalAlignment="Center"/>
        </StackPanel>

        <ui:InfoBar x:Name="PowerOffBar"
                    Title="DisplayHub Disabled"
                    Severity="Error" IsOpen="False" IsClosable="False"
                    Margin="0,0,0,12"/>

        <ui:InfoBar x:Name="DcActiveInfoBar"
                    Title="Dynamic Controls Active"
                    Severity="Informational" IsOpen="False" IsClosable="False"
                    Margin="0,0,0,12"/>

        <!-- Enable Toggle -->
        <ui:CardControl Margin="0,0,0,16">
            <ui:CardControl.Header>
                <StackPanel>
                    <TextBlock Text="Enable Dynamic Controls" FontSize="14" FontWeight="Medium"/>
                    <TextBlock Text="Adjust display settings with hotkeys in real-time"
                               Opacity="0.6" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </ui:CardControl.Header>
            <ui:ToggleSwitch x:Name="DynamicControlsToggle"
                             Checked="DynamicControlsToggle_Changed"
                             Unchecked="DynamicControlsToggle_Changed"/>
        </ui:CardControl>

        <!-- Current Values -->
        <TextBlock Text="Current Values" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <ui:Card Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="8">
                    <ui:SymbolIcon Symbol="BrightnessHigh20" FontSize="20" Margin="0,0,0,4"/>
                    <TextBlock Text="Gamma" FontWeight="Medium" HorizontalAlignment="Center" FontSize="12"/>
                    <TextBlock x:Name="GammaValueText" Text="1.00" HorizontalAlignment="Center"
                               FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center" Margin="8">
                    <ui:SymbolIcon Symbol="ArrowSync20" FontSize="20" Margin="0,0,0,4"/>
                    <TextBlock Text="Contrast" FontWeight="Medium" HorizontalAlignment="Center" FontSize="12"/>
                    <TextBlock x:Name="ContrastValueText" Text="50%" HorizontalAlignment="Center"
                               FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="8">
                    <ui:SymbolIcon Symbol="FlashSettings20" FontSize="20" Margin="0,0,0,4"/>
                    <TextBlock Text="Vibrance" FontWeight="Medium" HorizontalAlignment="Center" FontSize="12"/>
                    <TextBlock x:Name="VibranceValueText" Text="50" HorizontalAlignment="Center"
                               FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </ui:Card>

        <!-- Keybinds - Paired 2-column layout -->
        <TextBlock Text="Keybinds" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <TextBlock Text="Gamma" FontSize="12" FontWeight="Medium" Opacity="0.7" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ui:CardControl Grid.Column="0">
                <ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowUp20" Margin="0,0,6,0"/>
                        <TextBlock Text="Increase" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:Button x:Name="GammaUpKeybind" Content="Shift + Up" Click="ChangeKeybind_Click" Tag="GammaUp"
                           Appearance="Secondary" FontFamily="Consolas" MinWidth="110"/>
            </ui:CardControl>
            <ui:CardControl Grid.Column="2">
                <ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowDown20" Margin="0,0,6,0"/>
                        <TextBlock Text="Decrease" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:Button x:Name="GammaDownKeybind" Content="Shift + Down" Click="ChangeKeybind_Click" Tag="GammaDown"
                           Appearance="Secondary" FontFamily="Consolas" MinWidth="110"/>
            </ui:CardControl>
        </Grid>

        <TextBlock Text="Contrast" FontSize="12" FontWeight="Medium" Opacity="0.7" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ui:CardControl Grid.Column="0">
                <ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowRight20" Margin="0,0,6,0"/>
                        <TextBlock Text="Increase" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:Button x:Name="ContrastUpKeybind" Content="Shift + Right" Click="ChangeKeybind_Click" Tag="ContrastUp"
                           Appearance="Secondary" FontFamily="Consolas" MinWidth="110"/>
            </ui:CardControl>
            <ui:CardControl Grid.Column="2">
                <ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowLeft20" Margin="0,0,6,0"/>
                        <TextBlock Text="Decrease" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:Button x:Name="ContrastDownKeybind" Content="Shift + Left" Click="ChangeKeybind_Click" Tag="ContrastDown"
                           Appearance="Secondary" FontFamily="Consolas" MinWidth="110"/>
            </ui:CardControl>
        </Grid>

        <TextBlock Text="Vibrance" FontSize="12" FontWeight="Medium" Opacity="0.7" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ui:CardControl Grid.Column="0">
                <ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowUp20" Margin="0,0,6,0"/>
                        <TextBlock Text="Increase" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:Button x:Name="VibranceUpKeybind" Content="Shift + PgUp" Click="ChangeKeybind_Click" Tag="VibranceUp"
                           Appearance="Secondary" FontFamily="Consolas" MinWidth="110"/>
            </ui:CardControl>
            <ui:CardControl Grid.Column="2">
                <ui:CardControl.Header>
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowDown20" Margin="0,0,6,0"/>
                        <TextBlock Text="Decrease" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:Button x:Name="VibranceDownKeybind" Content="Shift + PgDn" Click="ChangeKeybind_Click" Tag="VibranceDown"
                           Appearance="Secondary" FontFamily="Consolas" MinWidth="110"/>
            </ui:CardControl>
        </Grid>

        <!-- DC Toggle Hotkey -->
        <TextBlock Text="Toggle Hotkey" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,6"/>
        <ui:CardControl Margin="0,0,0,16">
            <ui:CardControl.Header>
                <StackPanel>
                    <TextBlock Text="Toggle Dynamic Controls" FontSize="14" FontWeight="Medium"/>
                    <TextBlock Text="Global hotkey to switch between DC and Profile mode"
                               Opacity="0.6" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </ui:CardControl.Header>
            <ui:Button x:Name="DcToggleKeybind" Content="None" Click="ChangeDcToggle_Click"
                       Appearance="Secondary" FontFamily="Consolas" MinWidth="120"/>
        </ui:CardControl>
    </StackPanel>
</Page>
