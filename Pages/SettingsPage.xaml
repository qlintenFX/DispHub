<Page x:Class="DispHub.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Settings"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <StackPanel MaxWidth="700" Margin="16">
        <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>

        <!-- App Theme -->
        <TextBlock Text="Appearance" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <ui:CardControl Margin="0,0,0,8">
            <ui:CardControl.Header>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="App Theme" FontSize="14" FontWeight="Regular"/>
                    <TextBlock Text="Choose the application color theme" FontSize="12" Opacity="0.7"/>
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox x:Name="ThemeComboBox" SelectionChanged="ThemeComboBox_SelectionChanged" MinWidth="120">
                <ComboBoxItem Content="System"/>
                <ComboBoxItem Content="Light"/>
                <ComboBoxItem Content="Dark"/>
            </ComboBox>
        </ui:CardControl>

        <!-- Accent Color Picker -->
        <ui:CardControl Margin="0,0,0,12">
            <ui:CardControl.Header>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Accent Color" FontSize="14" FontWeight="Regular"/>
                    <TextBlock Text="Customize buttons and highlights" FontSize="12" Opacity="0.7"/>
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox x:Name="AccentColorComboBox" SelectionChanged="AccentColorComboBox_SelectionChanged" MinWidth="180">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="16" Height="16" CornerRadius="3" Margin="0,0,10,0"
                                    Background="{Binding Color}"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </ui:CardControl>

        <!-- Close Behavior -->
        <TextBlock Text="Behavior" FontSize="14" FontWeight="SemiBold" Margin="0,12,0,6"/>
        <ui:Card Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Close button behavior" FontWeight="Medium" FontSize="14" Margin="0,0,0,4"/>
                <TextBlock Text="Choose what happens when you close the window"
                           Opacity="0.6" FontSize="12" Margin="0,0,0,12"/>
                <RadioButton x:Name="CloseAppRadio" Content="Close application"
                             GroupName="CloseBehavior" Checked="CloseBehavior_Changed"/>
                <RadioButton x:Name="CloseToTrayRadio" Content="Minimize to system tray"
                             GroupName="CloseBehavior" Checked="CloseBehavior_Changed"
                             Margin="0,6,0,0"/>
            </StackPanel>
        </ui:Card>

        <!-- Start with Windows -->
        <ui:CardControl Margin="0,0,0,12">
            <ui:CardControl.Header>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Start with Windows" FontSize="14" FontWeight="Regular"/>
                    <TextBlock Text="Automatically start DispHub when Windows starts" FontSize="12" Opacity="0.7"/>
                </StackPanel>
            </ui:CardControl.Header>
            <ui:ToggleSwitch x:Name="StartWithWindowsToggle"
                             Checked="StartWithWindows_Changed"
                             Unchecked="StartWithWindows_Changed"/>
        </ui:CardControl>

        <!-- Tray Icon -->
        <TextBlock Text="Tray Icon" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <ui:CardControl Margin="0,0,0,12">
            <ui:CardControl.Header>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Left-click behavior" FontSize="14" FontWeight="Regular"/>
                    <TextBlock Text="Choose what happens when you left-click the tray icon" FontSize="12" Opacity="0.7"/>
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox x:Name="TrayLeftClickComboBox" SelectionChanged="TrayLeftClick_SelectionChanged" MinWidth="140">
                <ComboBoxItem Content="Open Settings"/>
                <ComboBoxItem Content="Do Nothing"/>
            </ComboBox>
        </ui:CardControl>

        <!-- Hotkeys -->
        <TextBlock Text="Hotkeys" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <ui:CardControl Margin="0,0,0,12">
            <ui:CardControl.Header>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Toggle DispHub" FontSize="14" FontWeight="Regular"/>
                    <TextBlock Text="Global hotkey to enable or disable DispHub" FontSize="12" Opacity="0.7"/>
                </StackPanel>
            </ui:CardControl.Header>
            <ui:Button x:Name="MasterToggleKeybind" Content="None" Click="MasterToggleKeybind_Click"
                       Appearance="Secondary" FontFamily="Consolas" MinWidth="120"/>
        </ui:CardControl>
    </StackPanel>
</Page>
