<Page x:Class="DisplayHub.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:DisplayHub.Helpers"
      Title="Settings"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16"
                  helpers:SmoothScrollBehavior.IsEnabled="True">
        <StackPanel MaxWidth="700">
            <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>

            <!-- Preview placeholder -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Border CornerRadius="10" ClipToBounds="True" Width="164" Height="98"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="Settings24" FontSize="28" Opacity="0.3"/>
                        <TextBlock Text="Preview" FontSize="10" Opacity="0.3" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <TextBlock Text="Configure application appearance, close behavior, and startup preferences."
                           FontSize="13" Opacity="0.6" Margin="16,0,0,0" MaxWidth="400"
                           TextWrapping="WrapWithOverflow" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- App Theme -->
            <TextBlock Text="Appearance" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <ui:CardControl Margin="0,0,0,8">
                <ui:CardControl.Header>
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="App Theme" FontSize="14" FontWeight="Regular"/>
                        <TextBlock Text="Choose the application color theme" FontSize="12" Opacity="0.5"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ComboBox x:Name="ThemeComboBox" SelectionChanged="ThemeComboBox_SelectionChanged" MinWidth="120">
                    <ComboBoxItem Content="System"/>
                    <ComboBoxItem Content="Light"/>
                    <ComboBoxItem Content="Dark"/>
                </ComboBox>
            </ui:CardControl>

            <!-- Close Behavior -->
            <TextBlock Text="Behavior" FontSize="14" FontWeight="SemiBold" Margin="0,12,0,6"/>
            <ui:Card Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="Close button behavior" FontWeight="Medium" FontSize="14" Margin="0,0,0,4"/>
                    <TextBlock Text="Choose what happens when you close the window"
                               Opacity="0.6" FontSize="12" Margin="0,0,0,12"/>
                    <RadioButton x:Name="CloseAppRadio" Content="Close application"
                                 GroupName="CloseBehavior" Checked="CloseBehavior_Changed"/>
                    <RadioButton x:Name="CloseToTrayRadio" Content="Minimize to system tray"
                                 GroupName="CloseBehavior" Checked="CloseBehavior_Changed"
                                 Margin="0,6,0,0"/>
                </StackPanel>
            </ui:Card>

            <!-- Start with Windows -->
            <ui:CardControl Margin="0,0,0,8">
                <ui:CardControl.Header>
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="Start with Windows" FontSize="14" FontWeight="Regular"/>
                        <TextBlock Text="Automatically start DisplayHub when Windows starts" FontSize="12" Opacity="0.5"/>
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:ToggleSwitch x:Name="StartWithWindowsToggle"
                                 Checked="StartWithWindows_Changed"
                                 Unchecked="StartWithWindows_Changed"/>
            </ui:CardControl>
        </StackPanel>
    </ScrollViewer>
</Page>
