<Page x:Class="DisplayHub.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Settings"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <StackPanel MaxWidth="700" Margin="16">
        <TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <ui:Card Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Start with Windows" FontWeight="Medium" FontSize="14"/>
                    <TextBlock Text="Automatically start DisplayHub when Windows starts"
                               Opacity="0.6" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
                <ui:ToggleSwitch x:Name="StartWithWindowsToggle"
                                 Grid.Column="1"
                                 Checked="StartWithWindows_Changed"
                                 Unchecked="StartWithWindows_Changed"/>
            </Grid>
        </ui:Card>

        <ui:Card Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Minimize to Tray" FontWeight="Medium" FontSize="14"/>
                    <TextBlock Text="Minimize to system tray instead of taskbar"
                               Opacity="0.6" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
                <ui:ToggleSwitch x:Name="MinimizeToTrayToggle"
                                 Grid.Column="1"
                                 Checked="MinimizeToTray_Changed"
                                 Unchecked="MinimizeToTray_Changed"/>
            </Grid>
        </ui:Card>

        <ui:Card Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Reset Display on Exit" FontWeight="Medium" FontSize="14"/>
                    <TextBlock Text="Restore default display settings when DisplayHub exits"
                               Opacity="0.6" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
                <ui:ToggleSwitch x:Name="ResetOnExitToggle"
                                 Grid.Column="1"
                                 Checked="ResetOnExit_Changed"
                                 Unchecked="ResetOnExit_Changed"/>
            </Grid>
        </ui:Card>

        <ui:Card Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="Reset Display Now" FontWeight="Medium" FontSize="14"/>
                    <TextBlock Text="Immediately restore default display settings"
                               Opacity="0.6" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
                <ui:Button Content="Reset" Icon="{ui:SymbolIcon ArrowReset20}"
                           Appearance="Secondary" Click="ResetNow_Click"/>
            </StackPanel>
        </ui:Card>
    </StackPanel>
</Page>
