<Page x:Class="DisplayHub.Pages.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:DisplayHub.Helpers"
      Title="About"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16"
                  helpers:SmoothScrollBehavior.IsEnabled="True">
        <StackPanel MaxWidth="1000">
            <!-- Contributors -->
            <TextBlock Text="Contributors" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,0"/>
            <TextBlock Text="The people behind DisplayHub" FontSize="14" Margin="4,12,0,8"
                       FontWeight="Regular" Opacity="0.75" TextWrapping="WrapWithOverflow"/>

            <ui:CardExpander Icon="{ui:SymbolIcon Code24}" ContentPadding="6" Margin="0,0,0,4">
                <ui:CardExpander.Header>
                    <TextBlock Text="Developers" FontSize="14" FontWeight="Regular" VerticalAlignment="Center"/>
                </ui:CardExpander.Header>
                <StackPanel Margin="8">
                    <TextBlock FontSize="14" Opacity="0.75" TextWrapping="WrapWithOverflow">
                        <Run FontWeight="SemiBold">qlintenFX</Run>
                        <Run> &#x2014; Creator of KeyedColors, DisplayHub developer</Run>
                    </TextBlock>
                </StackPanel>
            </ui:CardExpander>

            <ui:CardExpander Icon="{ui:SymbolIcon Translate24}" ContentPadding="6" Margin="0,0,0,8"
                             IsEnabled="False" Opacity="0.5">
                <ui:CardExpander.Header>
                    <TextBlock Text="Translators" FontSize="14" FontWeight="Regular" VerticalAlignment="Center"/>
                </ui:CardExpander.Header>
                <TextBlock Text="No translations yet" FontSize="14" Margin="8" Opacity="0.75"/>
            </ui:CardExpander>

            <!-- Support -->
            <TextBlock Text="Support" FontSize="20" FontWeight="SemiBold" Margin="0,24,0,0"/>
            <ui:InfoBar Title="DisplayHub is free and open source"
                        IsOpen="True" Severity="Informational" IsClosable="False" Margin="0,12,0,12">
                <TextBlock Text="You can build it yourself from source or download it from GitHub."
                           FontSize="12" Opacity="0.75" TextWrapping="WrapWithOverflow"/>
            </ui:InfoBar>

            <TextBlock FontSize="14" Margin="4,0,0,0" Opacity="0.75" TextWrapping="WrapWithOverflow"
                       Text="DisplayHub is a display settings manager with per-profile gamma, contrast, and vibrance control via customizable hotkeys. Originally based on KeyedColors by qlintenFX, rebuilt with a modern Fluent 2 UI inspired by FluentFlyout."/>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <ui:Anchor Content="GitHub" Icon="{ui:SymbolIcon Open24}"
                           NavigateUri="https://github.com/qlintenFX/DisplayHub" Margin="0,0,4,0"/>
            </StackPanel>

            <!-- Open Source Licenses -->
            <TextBlock Text="Open Source Licenses" FontSize="20" FontWeight="SemiBold" Margin="0,36,0,12"/>
            <TextBlock Text="DisplayHub is built with the following open source projects."
                       FontSize="14" Margin="4,0,0,0" Opacity="0.75" TextWrapping="WrapWithOverflow"/>

            <StackPanel Margin="0,12,0,0">
                <ui:CardAction Margin="0,4" Padding="16,12" IsChevronVisible="False"
                               Click="OpenUrl_Click" Tag="https://github.com/unchihugo/FluentFlyout">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <ui:TextBlock Text="FluentFlyout" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                            <ui:TextBlock Text="by Hugo Li (unchihugo)" FontSize="12" Opacity="0.6"
                                          VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <ui:TextBlock Text="GPL-3.0 license &#x2014; UI architecture &amp; code inspiration" Appearance="Secondary" FontSize="12"/>
                    </StackPanel>
                </ui:CardAction>

                <ui:CardAction Margin="0,4" Padding="16,12" IsChevronVisible="False"
                               Click="OpenUrl_Click" Tag="https://github.com/lepoco/wpfui">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <ui:TextBlock Text="WPF-UI" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                            <ui:TextBlock Text="by lepoco" FontSize="12" Opacity="0.6"
                                          VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <ui:TextBlock Text="MIT license &#x2014; Fluent design WPF controls" Appearance="Secondary" FontSize="12"/>
                    </StackPanel>
                </ui:CardAction>

                <ui:CardAction Margin="0,4" Padding="16,12" IsChevronVisible="False"
                               Click="OpenUrl_Click" Tag="https://github.com/qlintenFX/KeyedColors">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <ui:TextBlock Text="KeyedColors" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                            <ui:TextBlock Text="by qlintenFX" FontSize="12" Opacity="0.6"
                                          VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <ui:TextBlock Text="Original display services source" Appearance="Secondary" FontSize="12"/>
                    </StackPanel>
                </ui:CardAction>

                <ui:CardAction Margin="0,4" Padding="16,12" IsChevronVisible="False"
                               Click="OpenUrl_Click" Tag="https://github.com/Simnico99/MicaWPF">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <ui:TextBlock Text="MicaWPF" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                            <ui:TextBlock Text="by Simnico99" FontSize="12" Opacity="0.6"
                                          VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <ui:TextBlock Text="MIT license &#x2014; Mica effect for WPF" Appearance="Secondary" FontSize="12"/>
                    </StackPanel>
                </ui:CardAction>
            </StackPanel>

            <!-- Footer -->
            <DockPanel LastChildFill="False" Margin="0,24,0,12">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom" HorizontalAlignment="Left">
                    <ui:SymbolIcon Symbol="Star24" Filled="True" Width="24" Height="24" FontSize="16"
                                   VerticalAlignment="Center" Foreground="Gold"/>
                    <TextBlock Text="Enjoying DisplayHub?" HorizontalAlignment="Center" FontSize="12"
                               Opacity="0.5" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    <ui:Anchor Appearance="Transparent" Content="Star on GitHub" Icon="{ui:SymbolIcon Open24}"
                               NavigateUri="https://github.com/qlintenFX/DisplayHub" Margin="12,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
