<Page x:Class="DisplayHub.Pages.TaskbarWidgetPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Taskbar Widget"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <StackPanel MaxWidth="700" Margin="16">
        <TextBlock Text="Taskbar Widget" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>

        <!-- Preview placeholder -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Border CornerRadius="10" ClipToBounds="True" Width="164" Height="98"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="TextboxAlignBottom24" FontSize="28" Opacity="0.3"/>
                    <TextBlock Text="Widget Preview" FontSize="10" Opacity="0.3" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <TextBlock Text="Display the active profile in the Windows taskbar. The widget docks itself into the system taskbar area."
                       FontSize="13" Opacity="0.6" Margin="16,0,0,0" MaxWidth="400"
                       TextWrapping="WrapWithOverflow" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Enable/Disable -->
        <ui:CardControl Margin="0,0,0,8">
            <ui:CardControl.Header>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Enable Taskbar Widget" FontSize="14" FontWeight="Regular"/>
                    <TextBlock Text="Show the active profile directly in the Windows taskbar" FontSize="12" Opacity="0.5"/>
                </StackPanel>
            </ui:CardControl.Header>
            <ui:ToggleSwitch x:Name="WidgetEnabledToggle"
                             Checked="WidgetEnabled_Changed"
                             Unchecked="WidgetEnabled_Changed"/>
        </ui:CardControl>

        <!-- Position -->
        <ui:CardControl Margin="0,0,0,8">
            <ui:CardControl.Header>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Position" FontSize="14" FontWeight="Regular"/>
                    <TextBlock Text="Where to place the widget in the taskbar" FontSize="12" Opacity="0.5"/>
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox x:Name="PositionComboBox" SelectionChanged="Position_SelectionChanged" MinWidth="120">
                <ComboBoxItem Content="Left"/>
                <ComboBoxItem Content="Center"/>
                <ComboBoxItem Content="Right"/>
            </ComboBox>
        </ui:CardControl>

        <!-- Padding -->
        <ui:CardControl Margin="0,0,0,8">
            <ui:CardControl.Header>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Padding" FontSize="14" FontWeight="Regular"/>
                    <TextBlock Text="Distance from taskbar edge (pixels)" FontSize="12" Opacity="0.5"/>
                </StackPanel>
            </ui:CardControl.Header>
            <StackPanel Orientation="Horizontal">
                <Slider x:Name="PaddingSlider" Minimum="0" Maximum="100" Width="120"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        ValueChanged="Padding_ValueChanged"/>
                <TextBlock x:Name="PaddingValueText" Text="10" FontSize="13"
                           VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="24"/>
            </StackPanel>
        </ui:CardControl>

        <ui:InfoBar IsOpen="True" Severity="Informational" IsClosable="False" Margin="0,8,0,0"
                    Title="Restart may be required"
                    Message="Changes to widget position take effect automatically. Enabling or disabling the widget takes effect immediately."/>
    </StackPanel>
</Page>
