<Page x:Class="DispHub.Pages.TaskbarWidgetPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Taskbar Widget"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <StackPanel MaxWidth="700" Margin="16">
        <TextBlock Text="Taskbar Widget" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>

        <!-- Enable/Disable -->
        <ui:CardControl Icon="{ui:SymbolIcon TextboxAlignBottom24}" Margin="0,0,0,16">
            <ui:CardControl.Header>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Enable Taskbar Widget" FontSize="14" FontWeight="Regular"/>
                    <TextBlock Text="Turn taskbar display on or off" FontSize="12" Opacity="0.7"/>
                </StackPanel>
            </ui:CardControl.Header>
            <ui:ToggleSwitch x:Name="WidgetEnabledToggle"
                             Checked="WidgetEnabled_Changed"
                             Unchecked="WidgetEnabled_Changed"/>
        </ui:CardControl>

        <ui:InfoBar IsOpen="True" Severity="Warning" IsClosable="False" Margin="0,0,0,12"
                    Title="Visual issues may occur"
                    Message="The taskbar widget uses Win32 embedding which may have visual glitches on some systems or after explorer restarts."/>

        <!-- Position -->
        <ui:CardControl Icon="{ui:SymbolIcon ArrowMove24}" Margin="0,0,0,3">
            <ui:CardControl.Header>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Position" FontSize="14" FontWeight="Regular"/>
                    <TextBlock Text="Where to place the widget in the taskbar" FontSize="12" Opacity="0.7"/>
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox x:Name="PositionComboBox" SelectionChanged="Position_SelectionChanged" MinWidth="120">
                <ComboBoxItem Content="Left"/>
                <ComboBoxItem Content="Center"/>
                <ComboBoxItem Content="Right"/>
            </ComboBox>
        </ui:CardControl>

        <!-- Padding Settings (expandable) -->
        <ui:CardExpander Icon="{ui:SymbolIcon Wrench24}" ContentPadding="6" Margin="0,0,0,12">
            <ui:CardExpander.Header>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Padding Settings" FontSize="14" FontWeight="Regular"/>
                    <TextBlock Text="Fine-tune widget position with automatic or manual padding" FontSize="12" Opacity="0.7"/>
                </StackPanel>
            </ui:CardExpander.Header>
            <StackPanel>
                <ui:CardControl Icon="{ui:SymbolIcon PaddingRight24}" Margin="0,0,0,3">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Auto Padding" FontSize="14" FontWeight="Regular"/>
                            <TextBlock Text="Position next to the Windows Widgets button when on Left or Right" FontSize="12" Opacity="0.7"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:ToggleSwitch x:Name="AutoPaddingToggle"
                                     Checked="AutoPadding_Changed"
                                     Unchecked="AutoPadding_Changed"/>
                </ui:CardControl>
                <ui:CardControl Icon="{ui:SymbolIcon ArrowFit20}" Margin="0,0,0,0">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Manual Padding" FontSize="14" FontWeight="Regular"/>
                            <TextBlock Text="Additional offset in pixels from the edge" FontSize="12" Opacity="0.7"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:NumberBox x:Name="ManualPaddingBox"
                                  SpinButtonPlacementMode="Inline"
                                  Minimum="-500" Maximum="500"
                                  SmallChange="5" LargeChange="20"
                                  Value="0"
                                  ValueChanged="ManualPadding_ValueChanged"
                                  Width="140" ClearButtonEnabled="False"/>
                </ui:CardControl>
            </StackPanel>
        </ui:CardExpander>

        <!-- Clickable -->
        <ui:CardControl Icon="{ui:SymbolIcon ExpandUpRight24}" Margin="0,0,0,3">
            <ui:CardControl.Header>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Clickable" FontSize="14" FontWeight="Regular"/>
                    <TextBlock Text="Click the widget to open DispHub settings" FontSize="12" Opacity="0.7"/>
                </StackPanel>
            </ui:CardControl.Header>
            <ui:ToggleSwitch x:Name="ClickableToggle"
                             Checked="Clickable_Changed"
                             Unchecked="Clickable_Changed"/>
        </ui:CardControl>

        <!-- Background Blur -->
        <ui:CardControl Icon="{ui:SymbolIcon ColorBackground24}" Margin="0,0,0,3">
            <ui:CardControl.Header>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Background" FontSize="14" FontWeight="Regular"/>
                    <TextBlock Text="Show a subtle background behind the widget text" FontSize="12" Opacity="0.7"/>
                </StackPanel>
            </ui:CardControl.Header>
            <ui:ToggleSwitch x:Name="BackgroundBlurToggle"
                             Checked="BackgroundBlur_Changed"
                             Unchecked="BackgroundBlur_Changed"/>
        </ui:CardControl>

        <!-- Hide When Inactive -->
        <ui:CardControl Icon="{ui:SymbolIcon EyeOff24}" Margin="0,0,0,12">
            <ui:CardControl.Header>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Hide When Disabled" FontSize="14" FontWeight="Regular"/>
                    <TextBlock Text="Hide the widget when DispHub is disabled" FontSize="12" Opacity="0.7"/>
                </StackPanel>
            </ui:CardControl.Header>
            <ui:ToggleSwitch x:Name="HideWhenInactiveToggle"
                             Checked="HideWhenInactive_Changed"
                             Unchecked="HideWhenInactive_Changed"/>
        </ui:CardControl>
    </StackPanel>
</Page>
