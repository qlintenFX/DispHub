<UserControl x:Class="DisplayHub.Controls.TaskbarWidgetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Width="120" Height="40"
             Background="Transparent">
    <Border x:Name="WidgetBorder"
            Background="#22FFFFFF"
            CornerRadius="8"
            Padding="8,4"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Cursor="Hand"
            MouseEnter="WidgetBorder_MouseEnter"
            MouseLeave="WidgetBorder_MouseLeave"
            MouseLeftButtonUp="WidgetBorder_MouseLeftButtonUp">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,6,0"
                     Fill="#4CAF50" VerticalAlignment="Center"/>
            <TextBlock x:Name="ProfileText"
                       Text="No Profile"
                       FontSize="12"
                       Foreground="White"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="85"/>
        </StackPanel>
    </Border>
</UserControl>
