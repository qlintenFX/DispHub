<UserControl x:Class="DispHub.Controls.TaskbarWidgetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="130" Height="28"
             Background="Transparent"
             TextOptions.TextRenderingMode="ClearType"
             TextOptions.TextFormattingMode="Ideal"
             FontFamily="Segoe UI Variable, Segoe UI">
    <Border x:Name="MainBorder" CornerRadius="6" ClipToBounds="True"
            Cursor="Hand"
            MouseEnter="Border_MouseEnter"
            MouseLeave="Border_MouseLeave"
            MouseLeftButtonUp="Border_Click">
        <Border.Background>
            <SolidColorBrush x:Name="BackgroundBrush" Color="Transparent"/>
        </Border.Background>
        <Border x:Name="TopBorder" BorderThickness="0,1,0,0" CornerRadius="5" Margin="0,0,0,1">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                </Grid.RenderTransform>
                <TextBlock x:Name="ProfileText"
                           Text="No Profile"
                           FontSize="12"
                           FontWeight="Normal"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="120">
                    <TextBlock.Foreground>
                        <SolidColorBrush x:Name="TextBrush" Color="White"/>
                    </TextBlock.Foreground>
                </TextBlock>
            </Grid>
        </Border>
    </Border>
</UserControl>
