<UserControl x:Class="DisplayHub.Controls.TaskbarWidgetControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Width="140" Height="32"
             Background="Transparent"
             TextOptions.TextRenderingMode="ClearType"
             TextOptions.TextFormattingMode="Ideal"
             FontFamily="Segoe UI Variable, Segoe UI">
    <Border x:Name="MainBorder" CornerRadius="6" ClipToBounds="True"
            Cursor="Hand"
            MouseEnter="Border_MouseEnter"
            MouseLeave="Border_MouseLeave"
            MouseLeftButtonUp="Border_Click">
        <Border.Background>
            <SolidColorBrush Color="White" Opacity="0"/>
        </Border.Background>
        <Border x:Name="TopBorder" BorderThickness="0,1,0,0" CornerRadius="5" Margin="0,0,0,1">
            <Grid HorizontalAlignment="Left" VerticalAlignment="Center"
                  RenderTransformOrigin="0,0.5">
                <Grid.RenderTransform>
                    <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                </Grid.RenderTransform>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0,6,0">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,6,0"
                             VerticalAlignment="Center"/>
                    <TextBlock x:Name="ProfileText"
                               Text="No Profile"
                               FontSize="12"
                               FontWeight="Normal"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="110">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="White"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</UserControl>
