<Window
    x:Class="DisplayHub.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
    Title="DisplayHub"
    Height="1" Width="1"
    WindowStyle="None"
    ShowInTaskbar="False"
    Top="-9999" Left="-9999"
    Loaded="MainWindow_Loaded">
    <Grid>
        <tray:NotifyIcon
            x:Name="TrayIcon"
            Icon="/logo.ico"
            TooltipText="DisplayHub"
            LeftClick="TrayIcon_LeftClick"
            FocusOnLeftClick="False"
            MenuOnRightClick="True">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <ui:MenuItem x:Name="TrayOpenItem" Header="Open DisplayHub" Click="TrayOpen_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Settings20"/>
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                    <Separator/>
                    <ui:MenuItem x:Name="TrayExitItem" Header="Exit" Click="TrayExit_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="ArrowExit20"/>
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>
    </Grid>
</Window>
